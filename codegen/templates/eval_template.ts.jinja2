{#
eval_template.ts.jinja2

Harness contracts (verified against codebase):
  - readToolLogs() → { toolRequest: { name, args, success, duration_ms } }[]
    args is a JSON-encoded STRING — always JSON.parse before use
    (packages/test-utils/src/test-rig.ts:1372, :1391)
  - read_file       → arg: file_path         (base-declarations.ts:16)
  - read_many_files → arg: include[]          (glob patterns, NOT paths)
                      (core/src/tools/read-many-files.ts:53,
                       base-declarations.ts:87)
  - replace         → args: file_path, old_string, new_string   (#6 fix)
                      (base-declarations.ts:65)
  - write_file      → args: file_path, content
  - create_file     → args: file_path, file_text
  - shell           → args: command (string)
  - (rig as any).testDir → agent working directory after run

Pass/fail gates (ALL must pass):
  Gate 1 (hard) — every required context file was successfully read
  Gate 2 (hard) — at least one expected changed file differs from baseline
  Gate 3 (hard) — ALL expected changed files must be modified  (#1 fix)
  Gate 4 (hard) — no trivially modified files (delta < threshold)  (#5 fix)
  Gate 5 (soft) — required constraint symbols present in written code
#}
// =============================================================================
// {{ task.task_id }}.eval.ts
// Task     : {{ task.task_category }} | {{ task.difficulty_level }} | {{ task.language }}
// Repo     : {{ task.repo_id }} @ {{ task.commit_sha }}
//
// Required context (agent must discover and read):
{% for f in task.required_context_files %}
//   {{ f }}
{% endfor %}
// =============================================================================

import { evalTest } from '../test-helper.js';
import * as crypto from 'crypto';
import * as fs from 'fs';
import * as path from 'path';
import { minimatch } from 'minimatch';

// ─────────────────────────────────────────────────────────────────────────────
// HARNESS UTILITIES
// ─────────────────────────────────────────────────────────────────────────────

function parseArgs(raw: unknown): Record<string, unknown> {
  if (typeof raw === 'string') {
    try { return JSON.parse(raw) as Record<string, unknown>; } catch { return {}; }
  }
  if (raw !== null && typeof raw === 'object') return raw as Record<string, unknown>;
  return {};
}

/** Canonical forward-slash, no-leading-slash path. */
function norm(p: string): string {
  return String(p).replace(/\\/g, '/').replace(/^\.\//, '').replace(/^\/+/, '');
}

/**
 * Candidate path matches target path.
 * Asymmetric: candidate may be longer (absolute / deeper) but target is fixed.
 * Never flipped — prevents short-path false positives. (#4 fix family)
 */
function pathMatches(candidate: string, target: string): boolean {
  const c = norm(candidate);
  const t = norm(target);
  return c === t || c.endsWith('/' + t);
}

function md5(content: string): string {
  return crypto.createHash('md5').update(content, 'utf-8').digest('hex');
}

/**
 * Collect every file the agent SUCCESSFULLY read.
 *
 * Fix #2: handles `head -n 20 file.py` and other flag forms.
 * Strategy: strip leading flag tokens (start with - or are purely numeric)
 * from the arguments following the read command, then take the first
 * non-flag token as the file path.
 *
 * Fix #3: read_many_files uses glob include patterns, not concrete paths.
 * We approximate retrieval by matching required context files against include
 * glob patterns with minimatch.
 *
 * Only successful tool calls are counted. (#2 from previous round)
 */
function collectSuccessfulReads(
  logs: unknown[],
  requiredContextFiles: readonly string[],
): string[] {
  const paths: string[] = [];

  for (const entry of logs) {
    const log = entry as any;
    const name: string = log.toolRequest?.name ?? '';
    const success: boolean = !!(log.toolRequest?.success);
    if (!success) continue;

    const args = parseArgs(log.toolRequest?.args);

    if (name === 'read_file') {
      const p = String(args['file_path'] ?? args['path'] ?? '');
      if (p) paths.push(p);

    } else if (name === 'read_many_files') {
      const includeRaw = Array.isArray(args['include']) ? (args['include'] as unknown[]) : [];
      const include = includeRaw.filter((v): v is string => typeof v === 'string' && v.length > 0);

      // Approximate concrete retrieval by checking whether required files
      // are covered by include glob patterns.
      for (const rf of requiredContextFiles) {
        const nrf = norm(rf);
        if (include.some((pat) => minimatch(nrf, pat, { dot: true }))) {
          paths.push(rf);
        }
      }

    } else if (name === 'shell' || name === 'run_shell_command' || name === 'execute_bash') {
      const cmd = String(args['command'] ?? args['cmd'] ?? '');
      // Find all read-like sub-commands in the command string.
      // Pattern: cat/head/tail/less/more followed by optional flags and a path.
      // Fix #2: parse all file args while skipping flags, redirects, and
      // shell punctuation.
      const cmdRe = /\b(cat|head|tail|less|more|type)\b([^|;&\n]*)/g;
      for (const m of cmd.matchAll(cmdRe)) {
        const rest = m[2].trim();
        const tokens = rest.match(/(?:"[^"]*"|'[^']*'|\S+)/g) ?? [];

        const isRedirect = (x: string) => /^(?:[12]?>|>>|<|<<)$/.test(x);
        let stopAtRedirect = false;

        for (const tok of tokens) {
          const t = tok.replace(/^["']|["']$/g, '').trim();
          if (!t) continue;
          if (isRedirect(t)) { stopAtRedirect = true; continue; }
          if (stopAtRedirect) continue;
          if (t.startsWith('-') || /^[-+]?\d+$/.test(t) || /^[|&;]/.test(t)) continue;
          paths.push(t); // collect all file args, not just first
        }
      }
    }
  }

  return paths;
}

/**
 * Collect FINAL written content for each modified file (last write wins).
 * Fix #6 (docs): real edit tool args are old_string / new_string, not old_str/new_str.
 */
function collectFinalWrites(logs: unknown[]): Map<string, string> {
  const writes = new Map<string, string>();

  for (const entry of logs) {
    const log = entry as any;
    const name: string = log.toolRequest?.name ?? '';
    const success: boolean = !!(log.toolRequest?.success);
    if (!success) continue;

    const args = parseArgs(log.toolRequest?.args);

    if (name === 'write_file' || name === 'create_file' || name === 'overwrite_file') {
      const fp = norm(String(args['file_path'] ?? args['path'] ?? ''));
      const content = String(args['content'] ?? args['file_text'] ?? args['data'] ?? '');
      if (fp) writes.set(fp, content);

    } else if (name === 'replace') {
      // Real edit tool: file_path, old_string, new_string (base-declarations.ts:65)
      const fp = norm(String(args['file_path'] ?? args['path'] ?? ''));
      if (fp) writes.set(fp, '__PATCHED__');  // content resolved from testDir
    }
  }
  return writes;
}

// ─────────────────────────────────────────────────────────────────────────────
// TASK METADATA
// ─────────────────────────────────────────────────────────────────────────────

const TASK_META = {
  taskId:              {{ task.task_id | tojson }},
  difficultyLevel:     {{ task.difficulty_level | tojson }},
  difficultyScore:     {{ task.difficulty_score }},
  taskCategory:        {{ task.task_category | tojson }},
  language:            {{ task.language | tojson }},
  contextDistanceHops: {{ task.context_distance_hops }},
  irreducibilityScore: {{ task.irreducibility_score }},
  requiredContextFiles: {{ task.required_context_files | tojson }} as string[],
  changedFiles:        {{ task.changed_files | tojson }} as string[],
  constraintTypes:     {{ task.constraint_types | tojson }},
  repoId:              {{ task.repo_id | tojson }},
  commitSha:           {{ task.commit_sha | tojson }},
} as const;

/**
 * Baseline MD5 hashes of changed files at parent commit.
 * Used to detect genuine modification: only a file whose hash differs
 * from its baseline counts as modified. Prevents testDir pre-existing
 * content from being mistaken for agent work.
 */
const BASELINE_HASHES: Readonly<Record<string, string>> = {
  {% for filepath, content in task.files.items() %}
  {% if filepath in task.changed_files %}
  {{ filepath | tojson }}: {{ content | md5 | tojson }},
  {% endif %}
  {% endfor %}
} as const;

/**
 * Minimum number of meaningful characters the agent must ADD vs baseline
 * for a file modification to count as non-trivial. (#5 fix)
 * "Meaningful" = non-whitespace, non-comment characters in the delta.
 */
const MIN_DELTA_CHARS = 15;

/**
 * CPC targets: patterns matched against ACTUAL WRITTEN FILE CONTENT,
 * scoped to specific expected files. (#8, #10 from previous round)
 */
const CPC_TARGETS: ReadonlyArray<{
  readonly id: string;
  readonly pattern: RegExp;
  readonly description: string;
  readonly files: string[];
}> = [
  {% for target in task.constraint_propagation_targets %}
  {
    id:          {{ target.path | tojson }},
    pattern:     new RegExp({{ target.pattern | tojson }}, 'ms'),
    description: {{ target.description | tojson }},
    files: {{ (target.get('file', '') or '') | tojson }}
             ? [{{ (target.get('file', '') or '') | tojson }}]
             : ({{ task.changed_files | tojson }} as string[]),
  },
  {% endfor %}
] as const;

const CONSTRAINT_SYMBOLS: ReadonlyArray<string> =
  {{ task.assert_design.get('constraint_symbols', []) | tojson }};

// ─────────────────────────────────────────────────────────────────────────────
// EVAL DEFINITION
// ─────────────────────────────────────────────────────────────────────────────

evalTest('USUALLY_PASSES', {
  name: {{ (task.task_id ~ ' | ' ~ task.task_category ~ ' | ' ~ task.difficulty_level ~ ' | ' ~ task.language) | tojson }},

  prompt: {{ task.prompt | tojson }},

  files: {
    {% for filepath, content in task.files.items() %}
    {{ filepath | tojson }}: {{ content | tojson }},
    {% endfor %}
  },

  approvalMode: 'yolo',
  timeout: {{ task.timeout | default(90000) }},

  assert: async (rig, result) => {
    const assertStart = Date.now();
    const toolLogs: unknown[] = rig.readToolLogs();
    const testDir = (rig as any).testDir as string | undefined;

    // ── Stage 1: Retrieval ─────────────────────────────────────────────────
    const readPaths = collectSuccessfulReads(toolLogs, TASK_META.requiredContextFiles);
    const readNorm  = readPaths.map(norm);

    const retrievalResults = TASK_META.requiredContextFiles.map(rf => {
      const t = norm(rf);
      const matchCount = readNorm.filter(c => pathMatches(c, t)).length;
      return { file: rf, retrieved: matchCount > 0, readCount: matchCount };
    });

    const retrievalSuccess = retrievalResults.every(r => r.retrieved);
    const retrievalRate = TASK_META.requiredContextFiles.length === 0
      ? 1
      : retrievalResults.filter(r => r.retrieved).length /
        TASK_META.requiredContextFiles.length;

    // ── Stage 2: Modification detection ────────────────────────────────────
    const writeLog = collectFinalWrites(toolLogs);

    interface FileModification {
      path:           string;
      modified:       boolean;  // hash differs from baseline
      trivial:        boolean;  // delta too small (#5 fix)
      verifiable:     boolean;
      currentContent: string;
      deltaChars:     number;   // meaningful chars added vs baseline
    }

    /**
     * Compute meaningful delta between baseline and current content.
     * Fix #5: measure actual CHANGE, not absolute content size.
     * "Meaningful" = non-whitespace, non-single-line-comment characters.
     */
    function meaningfulDelta(baselineContent: string, currentContent: string): number {
      const strip = (s: string) =>
        s.replace(/\/\/[^\n]*/g, '').replace(/#[^\n]*/g, '').replace(/\s+/g, '');

      const before = strip(baselineContent);
      const after = strip(currentContent);

      if (before === after) return 0;

      let prefix = 0;
      while (
        prefix < before.length &&
        prefix < after.length &&
        before[prefix] === after[prefix]
      ) {
        prefix++;
      }

      let suffix = 0;
      while (
        suffix < before.length - prefix &&
        suffix < after.length - prefix &&
        before[before.length - 1 - suffix] === after[after.length - 1 - suffix]
      ) {
        suffix++;
      }

      const beforeChanged = before.length - prefix - suffix;
      const afterChanged = after.length - prefix - suffix;
      return Math.max(beforeChanged, afterChanged);
    }

    // Baseline content map: path → content (from files shipped in eval)
    const baselineContent: Record<string, string> = {
      {% for filepath, content in task.files.items() %}
      {% if filepath in task.changed_files %}
      {{ filepath | tojson }}: {{ content | tojson }},
      {% endif %}
      {% endfor %}
    };

    const modifications: FileModification[] = TASK_META.changedFiles.map(cf => {
      const cfNorm = norm(cf);
      const baseline = baselineContent[cf] ?? '';

      // Primary: testDir filesystem
      if (testDir) {
        try {
          const currentContent = fs.readFileSync(path.join(testDir, cf), 'utf-8');
          const currentHash = md5(currentContent);
          const baseHash = (BASELINE_HASHES as any)[cf] ?? '';
          const modified = baseHash !== '' && currentHash !== baseHash;
          const delta = modified ? meaningfulDelta(baseline, currentContent) : 0;
          return {
            path: cf, modified, trivial: modified && delta < MIN_DELTA_CHARS,
            verifiable: true, currentContent, deltaChars: delta,
          };
        } catch { /* fall through to write log */ }
      }

      // Fallback: write log (asymmetric match only — fix #4)
      const writeMatch = [...writeLog.entries()].find(([p]) => pathMatches(p, cfNorm));
      if (writeMatch) {
        const content = writeMatch[1];
        if (content === '__PATCHED__') {
          return { path: cf, modified: true, trivial: false,
                   verifiable: false, currentContent: '', deltaChars: -1 };
        }
        const baseHash = (BASELINE_HASHES as any)[cf] ?? '';
        const modified = baseHash !== md5(content);
        const delta = modified ? meaningfulDelta(baseline, content) : 0;
        return { path: cf, modified, trivial: modified && delta < MIN_DELTA_CHARS,
                 verifiable: true, currentContent: content, deltaChars: delta };
      }

      return { path: cf, modified: false, trivial: false,
               verifiable: true, currentContent: '', deltaChars: 0 };
    });

    const modifiedFiles  = modifications.filter(m => m.modified);
    const trivialFiles   = modifications.filter(m => m.trivial);
    const unmodifiedFiles = modifications.filter(m => !m.modified);

    const agentModifiedAny = modifiedFiles.length > 0;
    // Fix #1: ALL changed files must be addressed, not just a majority.
    const allFilesModified = modifications.every(m => m.modified);
    const hasTrivialWrites = trivialFiles.length > 0;

    // ── Stage 3: Unexpected writes ─────────────────────────────────────────
    const changedNorm = new Set(TASK_META.changedFiles.map(norm));
    const unexpectedWrites: string[] = [];
    if (testDir) {
      for (const [wPath] of writeLog) {
        if (!changedNorm.has(wPath) && !wPath.endsWith('.map')) {
          unexpectedWrites.push(wPath);
        }
      }
    }

    // ── Stage 4: CPC (scoped to specified files) ───────────────────────────
    const contentMap = new Map<string, string>();
    for (const m of modifications) {
      if (m.verifiable && m.currentContent) {
        contentMap.set(norm(m.path), m.currentContent);
      }
    }

    interface CpcResult {
      id: string; description: string;
      satisfied: boolean; inconclusive: boolean; checkedIn: string[];
    }
    const cpcResults: CpcResult[] = CPC_TARGETS.map(target => {
      const targetFiles = target.files.length > 0
        ? target.files : TASK_META.changedFiles;
      const relevantContent = targetFiles
        .map(f => contentMap.get(norm(f)) ?? '').filter(c => c.length > 0).join('\n\n');
      if (!relevantContent) {
        return { id: target.id, description: target.description,
                 satisfied: false, inconclusive: true, checkedIn: targetFiles };
      }
      return { id: target.id, description: target.description,
               satisfied: target.pattern.test(relevantContent),
               inconclusive: false, checkedIn: targetFiles };
    });

    const conclusiveCpc = cpcResults.filter(r => !r.inconclusive);
    const cpcScore = conclusiveCpc.length === 0
      ? (agentModifiedAny ? 0.5 : 0)
      : conclusiveCpc.filter(r => r.satisfied).length / conclusiveCpc.length;

    // ── Stage 5: Constraint symbols ────────────────────────────────────────
    const allModifiedContent = [...contentMap.values()].join('\n\n');
    const contentVerifiable = modifications.some(m => m.verifiable);
    const symbolResults = CONSTRAINT_SYMBOLS.map(s => ({
      symbol: s,
      found: allModifiedContent.includes(s),
      inconclusive: !agentModifiedAny,
    }));
    const symbolsPass = CONSTRAINT_SYMBOLS.length === 0
      || !contentVerifiable
      || symbolResults.every(r => r.found || r.inconclusive);

    // ── Stage 6: DTA / ICU ─────────────────────────────────────────────────
    const hops = TASK_META.contextDistanceHops;
    const dtaScore = retrievalResults.reduce((acc, r, i) => {
      const mu = r.retrieved ? 1 : 0;
      const gamma = r.retrieved && symbolsPass && agentModifiedAny ? 1 : 0;
      return acc + (mu * gamma) / (Math.max(1, hops - i) + 1);
    }, 0) / Math.max(1, TASK_META.requiredContextFiles.length);

    const uniqueReadCount = new Set(readNorm).size;
    const redundancy = Math.max(0, readPaths.length - uniqueReadCount);
    const icuScore = retrievalRate * (1 / (1 + redundancy * 0.1));

    // ── Stage 7: Operation sequence ────────────────────────────────────────
    const operationSequence: Array<{ op: string; file: string; idx: number }> = [];
    let opIdx = 0;
    for (const entry of toolLogs) {
      const log = entry as any;
      const n: string = log.toolRequest?.name ?? '';
      const a = parseArgs(log.toolRequest?.args);
      const ok = !!(log.toolRequest?.success);
      if (n === 'read_file' && ok) {
        const fp = String(a['file_path'] ?? '');
        if (fp) operationSequence.push({ op: 'read', file: norm(fp), idx: opIdx });
      } else if (['write_file', 'create_file', 'replace'].includes(n) && ok) {
        const fp = String(a['file_path'] ?? a['path'] ?? '');
        if (fp) operationSequence.push({ op: 'write', file: norm(fp), idx: opIdx });
      }
      opIdx++;
    }
    const firstWrite = operationSequence.find(o => o.op === 'write');
    const requiredContextReadBeforeEdit = TASK_META.requiredContextFiles.every(rf => {
      const t = norm(rf);
      const firstReqRead = operationSequence.find(o =>
        o.op === 'read' && (o.file === t || o.file.endsWith('/' + t))
      );
      return firstReqRead && (!firstWrite || firstReqRead.idx < firstWrite.idx);
    });

    // ── Stage 8: Failure mode (strict priority, no overlap) ────────────────
    // Fix #7: removed unused/wrong allRequiredModified.
    // Fix #8: trivial_edit only reachable when agentModifiedAny is true.
    // Fix #17 from previous round: inefficient_progress now reachable.
    const isLooping = readPaths.length > 6 && uniqueReadCount < readPaths.length * 0.4;

    let failureMode: string;
    if (!retrievalSuccess)           failureMode = 'context_substitution';
    else if (!agentModifiedAny)      failureMode = 'false_end';
    else if (hasTrivialWrites)       failureMode = 'trivial_edit';      // fix #8
    else if (!allFilesModified)      failureMode = 'partial_fix';       // fix #1
    else if (!symbolsPass && contentVerifiable)
                                     failureMode = 'retrieval_success_task_failure';
    else if (isLooping)              failureMode = 'loops';
    else if (toolLogs.length > 40)   failureMode = 'inefficient_progress';
    else                             failureMode = 'success';

    const taskSuccess = retrievalSuccess && agentModifiedAny &&
      !hasTrivialWrites && allFilesModified && symbolsPass;

    // ── Stage 9: Logging ───────────────────────────────────────────────────
    const logEntry = {
      ...TASK_META,
      timestamp: new Date().toISOString(),
      assertDurationMs: Date.now() - assertStart,
      retrievalSuccess, retrievalRate, retrievalResults,
      requiredContextReadBeforeEdit,
      agentModifiedAny, allFilesModified,
      modifiedFileCount: modifiedFiles.length,
      trivialFileCount: trivialFiles.length,
      unmodifiedExpectedFiles: unmodifiedFiles.map(m => m.path),
      unexpectedWrites, hasTrivialWrites,
      taskSuccess, cpcScore, cpcResults, dtaScore, icuScore,
      failureMode, symbolResults,
      toolCallCount: toolLogs.length,
      totalReadPaths: readPaths.length,
      uniqueReadPaths: uniqueReadCount,
      operationSequenceSummary: operationSequence.slice(0, 20),
      resultLength: result.length,
    };

    const logPath = process.env['L_SEED_LOG'] ?? process.env['LC_BENCH_LOG'];
    if (logPath) {
      try {
        fs.mkdirSync(path.dirname(logPath), { recursive: true });
        fs.appendFileSync(logPath, JSON.stringify(logEntry) + '\n');
      } catch (e) {
        process.stderr.write(`[L_SEED] Log write failed: ${String(e)}\n`);
      }
    } else {
      console.log('\nEVAL_RESULT:', JSON.stringify(logEntry, null, 2));
    }

    // ── Stage 10: Assert gates ─────────────────────────────────────────────

    if (!retrievalSuccess) {
      const missing = retrievalResults.filter(r => !r.retrieved).map(r => r.file);
      const seen = [...new Set(readNorm)].slice(0, 8);
      throw new Error(
        `[${TASK_META.taskId}] FAILED — required context not retrieved.\n` +
        `  Missing : ${missing.join(', ')}\n` +
        `  Seen    : ${seen.join(', ') || '(nothing)'}\n` +
        `  Failure : ${failureMode}`,
      );
    }

    if (!agentModifiedAny) {
      throw new Error(
        `[${TASK_META.taskId}] FAILED — no expected files were modified.\n` +
        `  Expected: ${TASK_META.changedFiles.join(', ')}\n` +
        `  Tool calls: ${toolLogs.length}\n` +
        `  Failure: ${failureMode}`,
      );
    }

    // Gate 3 fix (#1): ALL files, not majority.
    if (!allFilesModified) {
      throw new Error(
        `[${TASK_META.taskId}] FAILED — not all required files were modified.\n` +
        `  Modified  : ${modifiedFiles.map(m => m.path).join(', ')}\n` +
        `  Unmodified: ${unmodifiedFiles.map(m => m.path).join(', ')}\n` +
        `  Failure   : ${failureMode}`,
      );
    }

    if (hasTrivialWrites) {
      throw new Error(
        `[${TASK_META.taskId}] FAILED — modifications were trivial (delta < ${MIN_DELTA_CHARS} meaningful chars).\n` +
        `  Files: ${trivialFiles.map(m => `${m.path}(+${m.deltaChars})`).join(', ')}\n` +
        `  Failure: ${failureMode}`,
      );
    }

    if (!symbolsPass && contentVerifiable) {
      const missing = symbolResults.filter(r => !r.found && !r.inconclusive).map(r => r.symbol);
      throw new Error(
        `[${TASK_META.taskId}] FAILED — required symbols absent from implementation.\n` +
        `  Missing: ${missing.join(', ')}\n` +
        `  CPC: ${cpcScore.toFixed(2)} (${conclusiveCpc.filter(r => r.satisfied).length}/${conclusiveCpc.length})\n` +
        `  Failure: ${failureMode}`,
      );
    }
  },
});
